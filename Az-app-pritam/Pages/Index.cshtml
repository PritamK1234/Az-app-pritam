@page
@model IndexModel
@{
    ViewData["Title"] = "Family";
}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI',sans-serif;
        overflow-x: hidden;
        background: #FFFDF8;
    }

    /* LOADER */

    #loader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: white;
        z-index: 99999;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    .loader-house {
        font-size: 90px;
        animation: bounce 1.2s infinite;
    }

    @@keyframes bounce {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-20px);
        }
    }

    /* HERO */

    .hero {
        min-height: 100vh;
        background: linear-gradient( 135deg, #FFE8D6, #FFD6A5, #FDFFB6 );
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 50px;
    }

    .hero-grid {
        max-width: 1400px;
        width: 100%;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
    }

    .hero-title {
        font-size: 5rem;
        color: #6D4C41;
        font-weight: 900;
        line-height: 1.1;
    }

    .hero-text {
        font-size: 1.3rem;
        color: #555;
        margin: 30px 0;
    }

    .hero-btn {
        background: #FF8A65;
        color: white;
        border: none;
        padding: 16px 40px;
        border-radius: 50px;
        font-size: 18px;
        cursor: pointer;
    }

    .hero-svg {
        width: 100%;
        animation: float 5s infinite ease-in-out;
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-15px);
        }
    }

    /* VALUES */

    .section {
        padding: 100px 20px;
    }

    .section-title {
        text-align: center;
        font-size: 3rem;
        color: #6D4C41;
        margin-bottom: 70px;
    }

    .values {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 30px;
    }

    .value-card {
        width: 320px;
        background: white;
        padding: 35px;
        border-radius: 25px;
        text-align: center;
        box-shadow: 0 15px 30px rgba(0,0,0,.08);
        transition: .4s;
    }

        .value-card:hover {
            transform: translateY(-10px);
        }

    .value-icon {
        font-size: 70px;
    }

    /* COUNTERS */

    .stats {
        background: #FFF4E6;
        padding: 100px 20px;
    }

    .stats-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 40px;
    }

    .stat {
        text-align: center;
    }

        .stat h2 {
            font-size: 4rem;
            color: #FF8A65;
        }

        .stat p {
            font-size: 1.2rem;
        }

    /* MEMORIES */

    .gallery {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 25px;
    }

    .memory {
        height: 250px;
        border-radius: 20px;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 80px;
        transition: .4s;
    }

        .memory:hover {
            transform: scale(1.05);
        }

    .bg1 {
        background: #FFE0B2;
    }

    .bg2 {
        background: #FFD180;
    }

    .bg3 {
        background: #FFCCBC;
    }

    .bg4 {
        background: #FFF9C4;
    }

    /* QUOTE */

    .quote {
        background: #6D4C41;
        color: white;
        text-align: center;
        padding: 120px 30px;
    }

        .quote h2 {
            font-size: 3rem;
            margin-bottom: 25px;
        }

        .quote p {
            max-width: 900px;
            margin: auto;
            font-size: 1.4rem;
        }

    @@media(max-width:900px) {

        .hero-grid {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .hero-title {
            font-size: 3rem;
        }
    }

</style>

<div id="loader">
    <div class="loader-house">🏡</div>
    <h3>Loading Family World...</h3>
</div>

<section class="hero">

    <div class="hero-grid">

        <div>

            <h1 class="hero-title">
                Family Is Where Life Begins ❤️
            </h1>

            <p class="hero-text">
                Pritam Kadam
            </p>

            <button class="hero-btn">
                Pritam Kadam
            </button>

        </div>

        <div>

            <svg class="hero-svg" viewBox="0 0 500 400">

                <circle cx="150" cy="120" r="40" fill="#FFB74D" />
                <circle cx="250" cy="100" r="45" fill="#FF8A65" />
                <circle cx="350" cy="120" r="40" fill="#FFB74D" />

                <rect x="120" y="170" width="60" height="90" rx="20" fill="#FFD54F" />
                <rect x="220" y="150" width="70" height="110" rx="20" fill="#FF7043" />
                <rect x="330" y="170" width="60" height="90" rx="20" fill="#FFD54F" />

            </svg>

        </div>

    </div>

</section>

<section class="section">

    <h2 class="section-title">
        Family Values
    </h2>

    <div class="values">

        <div class="value-card">
            <div class="value-icon">❤️</div>
            <h3>Love</h3>
            <p>Unconditional affection and care.</p>
        </div>

        <div class="value-card">
            <div class="value-icon">🤝</div>
            <h3>Support</h3>
            <p>Standing together through every challenge.</p>
        </div>

        <div class="value-card">
            <div class="value-icon">🏡</div>
            <h3>Togetherness</h3>
            <p>Building memories and traditions.</p>
        </div>

    </div>

</section>

<section class="stats">

    <div class="stats-grid">

        <div class="stat">
            <h2>365</h2>
            <p>Days of Care</p>
        </div>

        <div class="stat">
            <h2>24/7</h2>
            <p>Support System</p>
        </div>

        <div class="stat">
            <h2>∞</h2>
            <p>Love & Trust</p>
        </div>

        <div class="stat">
            <h2>100%</h2>
            <p>Family Bond</p>
        </div>

    </div>

</section>

<section class="section">

    <h2 class="section-title">
        Family Memories
    </h2>

    <div class="gallery">

        <div class="memory bg1">🎂</div>
        <div class="memory bg2">🎉</div>
        <div class="memory bg3">📸</div>
        <div class="memory bg4">🌳</div>

    </div>

</section>

<section class="quote">

    <h2>Family Quote</h2>

    <p>
        The love of a family is life's greatest blessing.
    </p>

</section>

<script>

    window.addEventListener("load",function(){

        setTimeout(function(){

            document.getElementById("loader").style.display="none";

        },1200);

    });

</script>