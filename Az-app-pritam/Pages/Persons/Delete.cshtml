@page
@model Az_app_pritam.Pages_Persons.DeleteModel

@{
    ViewData["Title"] = "Delete Person";
}

<style>
    body {
        background: #f4f7fb;
    }

    .page-header {
        background: linear-gradient(135deg,#7f1d1d,#b91c1c);
        color: white;
        padding: 30px;
        border-radius: 20px;
        margin-bottom: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,.15);
    }

        .page-header h1 {
            margin: 0;
            font-size: 2rem;
            font-weight: 700;
        }

        .page-header p {
            margin-top: 8px;
            opacity: .85;
        }

    .delete-card {
        max-width: 800px;
        margin: auto;
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
    }

    .warning-box {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
        border-radius: 15px;
        padding: 20px;
        text-align: center;
        margin-bottom: 30px;
    }

    .warning-icon {
        font-size: 50px;
        margin-bottom: 10px;
    }

    .avatar {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: linear-gradient(135deg,#ef4444,#dc2626);
        color: white;
        font-size: 36px;
        font-weight: bold;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: auto;
        margin-bottom: 20px;
    }

    .person-name {
        text-align: center;
        font-size: 1.8rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 5px;
    }

    .person-id {
        text-align: center;
        color: #64748b;
        margin-bottom: 30px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 18px;
        border-bottom: 1px solid #e2e8f0;
    }

    .info-label {
        font-weight: 600;
        color: #475569;
    }

    .info-value {
        font-weight: 500;
        color: #0f172a;
    }

    .button-group {
        display: flex;
        gap: 12px;
        margin-top: 35px;
    }

    .btn-delete {
        background: linear-gradient(135deg,#dc2626,#ef4444);
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-delete:hover {
            transform: translateY(-2px);
        }

    .btn-back {
        background: #f1f5f9;
        color: #334155;
        padding: 12px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: .3s;
    }

        .btn-back:hover {
            background: #e2e8f0;
            color: #0f172a;
        }
</style>

<div class="page-header">
    <h1>🗑 Delete Person</h1>
    <p>Permanently remove this person from the directory.</p>
</div>

<div class="delete-card">

    <div class="warning-box">
        <div class="warning-icon">⚠️</div>
        <h4>Are you sure?</h4>
        <p class="mb-0">
            This action cannot be undone. The selected record will be permanently deleted.
        </p>
    </div>

    <div class="avatar">
        @($"{Model.Person.FirstName?[0]}{Model.Person.LastName?[0]}")
    </div>

    <div class="person-name">
        @Model.Person.FirstName @Model.Person.LastName
    </div>

    <div class="person-id">
        Person ID : @Model.Person.Id
    </div>

    <div class="info-row">
        <div class="info-label">First Name</div>
        <div class="info-value">@Model.Person.FirstName</div>
    </div>

    <div class="info-row">
        <div class="info-label">Last Name</div>
        <div class="info-value">@Model.Person.LastName</div>
    </div>

    <div class="info-row">
        <div class="info-label">Date Of Birth</div>
        <div class="info-value">
            @Model.Person.DateOfBirth.ToString("dd MMMM yyyy")
        </div>
    </div>

    <form method="post">

        <input type="hidden" asp-for="Person.Id" />

        <div class="button-group">

            <button type="submit" class="btn-delete">
                🗑 Confirm Delete
            </button>

            <a asp-page="./Index" class="btn-back">
                ← Cancel
            </a>

        </div>

    </form>

</div>