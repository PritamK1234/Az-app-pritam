@page
@model Az_app_pritam.Pages_Persons.DetailsModel

@{
    ViewData["Title"] = "Person Details";
}

<style>
    body {
        background: #f4f7fb;
    }

    .page-header {
        background: linear-gradient(135deg,#0f172a,#1e293b);
        color: white;
        padding: 30px;
        border-radius: 20px;
        margin-bottom: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,.15);
    }

        .page-header h1 {
            margin: 0;
            font-size: 2rem;
            font-weight: 700;
        }

        .page-header p {
            opacity: .8;
            margin-top: 8px;
        }

    .details-card {
        max-width: 800px;
        margin: auto;
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
    }

    .profile-section {
        text-align: center;
        margin-bottom: 35px;
    }

    .avatar {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: linear-gradient(135deg,#3b82f6,#8b5cf6);
        color: white;
        font-size: 36px;
        font-weight: bold;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: auto;
        margin-bottom: 15px;
    }

    .person-name {
        font-size: 1.8rem;
        font-weight: 700;
        color: #0f172a;
    }

    .person-id {
        color: #64748b;
        margin-top: 5px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 18px;
        border-bottom: 1px solid #e2e8f0;
    }

    .info-label {
        font-weight: 600;
        color: #475569;
    }

    .info-value {
        color: #0f172a;
        font-weight: 500;
    }

    .button-group {
        display: flex;
        gap: 12px;
        margin-top: 30px;
    }

    .btn-edit {
        background: linear-gradient(135deg,#2563eb,#3b82f6);
        color: white;
        padding: 12px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: .3s;
    }

        .btn-edit:hover {
            color: white;
            transform: translateY(-2px);
        }

    .btn-back {
        background: #f1f5f9;
        color: #334155;
        padding: 12px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: .3s;
    }

        .btn-back:hover {
            background: #e2e8f0;
            color: #0f172a;
        }

    .status-badge {
        background: #dcfce7;
        color: #166534;
        padding: 6px 14px;
        border-radius: 999px;
        font-size: .85rem;
        font-weight: 600;
    }
</style>

<div class="page-header">
    <h1>👤 Person Details</h1>
    <p>View complete information for this person.</p>
</div>

<div class="details-card">

    <div class="profile-section">

        <div class="avatar">
            @($"{Model.Person.FirstName?[0]}{Model.Person.LastName?[0]}")
        </div>

        <div class="person-name">
            @Model.Person.FirstName @Model.Person.LastName
        </div>

        <div class="person-id">
            Person ID : @Model.Person.Id
        </div>

        <div class="mt-3">
            <span class="status-badge">
                Active
            </span>
        </div>

    </div>

    <div class="info-row">
        <div class="info-label">First Name</div>
        <div class="info-value">@Model.Person.FirstName</div>
    </div>

    <div class="info-row">
        <div class="info-label">Last Name</div>
        <div class="info-value">@Model.Person.LastName</div>
    </div>

    <div class="info-row">
        <div class="info-label">Date Of Birth</div>
        <div class="info-value">
            @Model.Person.DateOfBirth.ToString("dd MMMM yyyy")
        </div>
    </div>

    <div class="button-group">

        <a asp-page="./Edit"
           asp-route-id="@Model.Person.Id"
           class="btn-edit">
            ✏ Edit Person
        </a>

        <a asp-page="./Index"
           class="btn-back">
            ← Back To List
        </a>

    </div>

</div>